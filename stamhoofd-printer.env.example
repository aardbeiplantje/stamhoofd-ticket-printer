# Stamhoofd Printer Environment Configuration
# Copy this to /etc/stamhoofd-printer.env and fill in your values

STAMHOOFD_ORG_ID=your_org_id
# Preferred: comma-separated webshop IDs
STAMHOOFD_WEBSHOP_IDS=webshop_id_1,webshop_id_2
# Backward-compatible single webshop variable (optional if STAMHOOFD_WEBSHOP_IDS is set)
# STAMHOOFD_WEBSHOP_ID=your_webshop_id
STAMHOOFD_API_KEY=your_api_key
MX10_BLE_ADDRESS=XX:XX:XX:XX:XX:XX
MX10_BLE_ADDR_TYPE=public
STAMHOOFD_PRINTED_BASE_DIR=/var/lib/stamhoofd-printer/printed_orders
STAMHOOFD_STATE_DIR=/var/lib/stamhoofd-printer
# Optional explicit file path for current sleep/back-off state.
# STAMHOOFD_SLEEP_STATE_FILE=/var/lib/stamhoofd-printer/sleep_state.json
MX10_FONT_SIZE=24
MX10_KEEPALIVE_SECONDS=12
MX10_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
STAMHOOFD_EVENT_DURATION_HOURS=6
STAMHOOFD_RATE_SAFETY_MARGIN=0.9
# Optional max number of concurrent webshop API fetches per poll cycle.
# STAMHOOFD_MAX_PARALLEL_POLLS=4
# Optional hard override for poll interval (seconds). Leave unset for auto-calculation.
# STAMHOOFD_POLL_SECONDS=12
